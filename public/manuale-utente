    <a href="#toc" class="nav-link" data-sec="toc"><i class="fas fa-list-ul"></i>Indice</a>

    <div class="sidebar-group-label">Il sito</div>
    <a href="#sec-overview" class="nav-link" data-sec="sec-overview"><i class="fas fa-globe"></i>1. Panoramica</a>
    <a href="#sec-nav" class="nav-link" data-sec="sec-nav"><i class="fas fa-bars"></i>2. Navigazione</a>

    <div class="sidebar-group-label">Pagine</div>
    <a href="#sec-home" class="nav-link" data-sec="sec-home"><i class="fas fa-house"></i>3. Home</a>
    <a href="#sec-about" class="nav-link" data-sec="sec-about"><i class="fas fa-info-circle"></i>4. Cos'è ReNU</a>
    <a href="#sec-research" class="nav-link" data-sec="sec-research"><i class="fas fa-flask"></i>5. Ricerca</a>
    <a href="#sec-therapies" class="nav-link" data-sec="sec-therapies"><i class="fas fa-pills"></i>6. Terapie</a>
    <a href="#sec-diagnosis" class="nav-link" data-sec="sec-diagnosis"><i class="fas fa-microscope"></i>7. Diagnosi</a>
