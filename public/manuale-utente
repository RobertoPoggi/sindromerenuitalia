  <div class="header-actions">
    <span class="btn-chip btn-chip-green"><i class="fas fa-shield-halved"></i>GDPR v2.0</span>
    <button class="btn-chip btn-chip-print" onclick="window.print()"><i class="fas fa-print"></i>Stampa</button>
    <a href="/it/home" class="btn-chip btn-chip-white"><i class="fas fa-arrow-left"></i>Sito</a>
  </div>
</header>

<!-- Overlay mobile -->
<div class="overlay" id="overlay" onclick="toggleSidebar()"></div>

<!-- ══════════════════════════════════════
     APP BODY
══════════════════════════════════════ -->
<div class="app-body">

  <!-- ════ SIDEBAR ════ -->
  <aside class="sidebar" id="sidebar">
