<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Manuale d'Uso – Sindrome ReNU Italia APS</title>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<style>
  :root {
    --primary: #082050;
    --accent:  #1078C0;
    --sky:     #45B8EC;
    --light:   #f0f9ff;
    --text:    #1e293b;
    --muted:   #64748b;
    --border:  #e2e8f0;
    --success: #16a34a;
    --warn:    #d97706;
    --danger:  #dc2626;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
    background: #f8fafc;
    color: var(--text);
    line-height: 1.7;
    font-size: 15px;
  }

  /* ── HEADER ── */
  header {
    background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
    color: #fff;
    padding: 0;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 4px 20px rgba(0,0,0,0.3);
  }
  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 16px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
  }
  .header-brand { display: flex; align-items: center; gap: 14px; }
  .header-brand img { height: 48px; filter: brightness(0) invert(1); opacity: .9; }
  .header-brand-text h1 { font-size: 20px; font-weight: 800; letter-spacing: -.3px; }
  .header-brand-text p { font-size: 11px; color: #93c5fd; margin-top: 1px; }
  .header-meta { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
  .badge {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .5px;
    padding: 4px 10px;
    border-radius: 100px;
    text-transform: uppercase;
  }
  .badge-green  { background: #dcfce7; color: #166534; }
  .badge-blue   { background: #dbeafe; color: #1e40af; }
  .badge-orange { background: #fef3c7; color: #92400e; }
  .btn-back {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: #fff;
    text-decoration: none;
    font-size: 13px;
    background: rgba(255,255,255,.15);
    border: 1px solid rgba(255,255,255,.3);
    padding: 6px 14px;
    border-radius: 8px;
    transition: background .2s;
  }
  .btn-back:hover { background: rgba(255,255,255,.25); }

  /* ── LAYOUT ── */
  .container { max-width: 1200px; margin: 0 auto; padding: 32px 24px; display: grid; grid-template-columns: 260px 1fr; gap: 32px; align-items: start; }
  @media(max-width: 900px) { .container { grid-template-columns: 1fr; } }

  /* ── SIDEBAR ── */
  .sidebar {
    position: sticky;
    top: 85px;
    background: #fff;
    border-radius: 16px;
    border: 1px solid var(--border);
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,0,0,.06);
  }
  .sidebar-title {
    background: linear-gradient(135deg, var(--primary), var(--accent));
    color: #fff;
    padding: 14px 18px;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .sidebar nav { padding: 8px 0; }
  .sidebar nav a {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 18px;
    font-size: 13px;
    color: var(--muted);
    text-decoration: none;
    border-left: 3px solid transparent;
    transition: all .15s;
  }
  .sidebar nav a:hover, .sidebar nav a.active {
    color: var(--accent);
    background: var(--light);
    border-left-color: var(--accent);
  }
  .sidebar nav a i { width: 16px; text-align: center; font-size: 12px; }
  .sidebar nav .section-label {
    padding: 12px 18px 4px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1px;
    color: #94a3b8;
    text-transform: uppercase;
    border: none;
    pointer-events: none;
  }

  /* ── CONTENT ── */
  .content { min-width: 0; }

  /* ── COVER CARD ── */
  .cover-card {
    background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 60%, var(--sky) 100%);
    color: #fff;
    border-radius: 20px;
    padding: 40px;
    margin-bottom: 32px;
    position: relative;
    overflow: hidden;
  }
  .cover-card::before {
    content: '';
    position: absolute;
    top: -60px; right: -60px;
    width: 240px; height: 240px;
    background: rgba(255,255,255,.07);
    border-radius: 50%;
  }
  .cover-card h1 { font-size: 30px; font-weight: 800; margin-bottom: 8px; position: relative; }
  .cover-card p { font-size: 15px; color: #bfdbfe; max-width: 560px; position: relative; }
  .cover-meta { display: flex; gap: 8px; margin-top: 20px; flex-wrap: wrap; }
  .cover-meta span {
    background: rgba(255,255,255,.15);
    border: 1px solid rgba(255,255,255,.25);
    border-radius: 100px;
    padding: 4px 12px;
    font-size: 12px;
    font-weight: 600;
  }

  /* ── SECTION ── */
  section {
    background: #fff;
    border-radius: 16px;
    border: 1px solid var(--border);
    padding: 36px;
    margin-bottom: 24px;
    box-shadow: 0 2px 8px rgba(0,0,0,.04);
    scroll-margin-top: 100px;
  }
  .section-header {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 2px solid var(--light);
  }
  .section-icon {
    width: 48px; height: 48px;
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    font-size: 20px;
    flex-shrink: 0;
  }
  .icon-blue   { background: #dbeafe; color: var(--accent); }
  .icon-green  { background: #dcfce7; color: var(--success); }
  .icon-purple { background: #f3e8ff; color: #7c3aed; }
  .icon-red    { background: #fee2e2; color: var(--danger); }
  .icon-orange { background: #fef3c7; color: var(--warn); }
  .icon-sky    { background: #e0f2fe; color: #0369a1; }
  .icon-teal   { background: #ccfbf1; color: #0f766e; }
  .icon-pink   { background: #fce7f3; color: #be185d; }

  .section-header-text h2 { font-size: 21px; font-weight: 800; color: var(--primary); }
  .section-header-text p  { font-size: 13px; color: var(--muted); margin-top: 2px; }

  h3 { font-size: 17px; font-weight: 700; color: var(--primary); margin: 24px 0 10px; display: flex; align-items: center; gap: 8px; }
  h3 i { font-size: 14px; color: var(--accent); }
  h4 { font-size: 14px; font-weight: 700; color: var(--text); margin: 16px 0 6px; }
  p  { margin-bottom: 12px; color: #374151; }
  ul, ol { margin: 0 0 14px 20px; color: #374151; }
  li { margin-bottom: 6px; }

  /* ── INFO BOXES ── */
  .info-box {
    border-radius: 12px;
    padding: 16px 20px;
    margin: 16px 0;
    display: flex;
    gap: 14px;
    font-size: 13.5px;
  }
  .info-box i { font-size: 18px; flex-shrink: 0; margin-top: 1px; }
  .info-box-blue   { background: #eff6ff; border: 1px solid #bfdbfe; color: #1e40af; }
  .info-box-green  { background: #f0fdf4; border: 1px solid #bbf7d0; color: #166534; }
  .info-box-orange { background: #fffbeb; border: 1px solid #fde68a; color: #92400e; }
  .info-box-red    { background: #fef2f2; border: 1px solid #fecaca; color: #991b1b; }
  .info-box-gray   { background: #f8fafc; border: 1px solid var(--border); color: #475569; }

  /* ── FEATURE CARDS ── */
  .feature-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 14px; margin: 16px 0; }
  .feature-card {
    background: var(--light);
    border: 1px solid #bae6fd;
    border-radius: 12px;
    padding: 18px;
  }
  .feature-card .fc-icon { font-size: 22px; margin-bottom: 8px; }
  .feature-card .fc-title { font-weight: 700; font-size: 14px; color: var(--primary); margin-bottom: 4px; }
  .feature-card .fc-desc  { font-size: 12px; color: var(--muted); }

  /* ── PAGE CARDS ── */
  .page-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 14px; margin: 16px 0; }
  .page-card {
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 18px 20px;
    background: #fff;
    transition: box-shadow .2s;
  }
  .page-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,.08); }
  .page-card .pc-header { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
  .page-card .pc-icon { width: 36px; height: 36px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 15px; flex-shrink: 0; }
  .page-card .pc-title { font-weight: 700; font-size: 15px; color: var(--primary); }
  .page-card .pc-url   { font-size: 11px; color: var(--muted); margin-bottom: 8px; font-family: monospace; background: #f1f5f9; padding: 2px 6px; border-radius: 4px; display: inline-block; }
  .page-card .pc-desc  { font-size: 13px; color: #374151; }

  /* ── STEP LIST ── */
  .steps { counter-reset: step; margin: 16px 0; }
  .step  { display: flex; gap: 16px; margin-bottom: 20px; }
  .step-num {
    width: 34px; height: 34px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--primary), var(--accent));
    color: #fff;
    font-weight: 800;
    font-size: 14px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    counter-increment: step;
  }
  .step-body { flex: 1; }
  .step-body b { display: block; font-size: 15px; color: var(--primary); margin-bottom: 4px; }
  .step-body p { margin: 0; font-size: 13.5px; }

  /* ── TABLE ── */
  .data-table { width: 100%; border-collapse: collapse; font-size: 13px; margin: 14px 0; }
  .data-table th { background: var(--light); color: var(--primary); font-weight: 700; padding: 10px 14px; text-align: left; border: 1px solid #bae6fd; }
  .data-table td { padding: 9px 14px; border: 1px solid var(--border); vertical-align: top; }
  .data-table tr:nth-child(even) td { background: #f8fafc; }

  /* ── CODE ── */
  code {
    font-family: 'Courier New', monospace;
    background: #f1f5f9;
    border: 1px solid var(--border);
    border-radius: 5px;
    padding: 2px 7px;
    font-size: 12.5px;
    color: #be185d;
  }

  /* ── CONTACTS GRID ── */
  .contacts-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 12px; margin: 16px 0; }
  .contact-card {
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 14px 16px;
    text-align: center;
  }
  .contact-card i { font-size: 22px; color: var(--accent); margin-bottom: 6px; display: block; }
  .contact-card .cc-label { font-size: 11px; color: var(--muted); text-transform: uppercase; font-weight: 700; letter-spacing: .5px; }
  .contact-card .cc-value { font-size: 13px; font-weight: 600; color: var(--primary); margin-top: 3px; }
  .contact-card a { color: var(--accent); text-decoration: none; }
  .contact-card a:hover { text-decoration: underline; }

  /* ── ADMIN TABLE ── */
  .admin-tabs { display: flex; flex-wrap: wrap; gap: 8px; margin: 16px 0; }
  .admin-tab {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    border-radius: 10px;
    font-size: 13px;
    font-weight: 600;
    border: 1px solid var(--border);
    background: #fff;
  }
  .admin-tab i { font-size: 14px; }

  /* ── URL PILL ── */
  .url-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--primary);
    color: #fff;
    border-radius: 8px;
    padding: 8px 16px;
    font-size: 13px;
    font-weight: 700;
    font-family: monospace;
    text-decoration: none;
    margin: 4px 0;
    word-break: break-all;
  }
  .url-pill.light { background: var(--light); color: var(--accent); border: 1px solid #bae6fd; }

  /* ── TOC QUICK JUMP ── */
  .quick-jump { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 24px; }
  .qj-btn {
    display: inline-flex; align-items: center; gap: 6px;
    background: #fff; border: 1px solid var(--border);
    border-radius: 8px; padding: 7px 13px;
    font-size: 12.5px; color: var(--accent); font-weight: 600;
    text-decoration: none; transition: all .15s;
  }
  .qj-btn:hover { background: var(--light); border-color: var(--accent); }
  .qj-btn i { font-size: 11px; }

  /* ── FOOTER ── */
  footer {
    background: var(--primary);
    color: #94a3b8;
    text-align: center;
    padding: 24px;
    font-size: 12px;
    margin-top: 48px;
  }
  footer a { color: var(--sky); text-decoration: none; }

  /* ── PRINT ── */
  @media print {
    .sidebar, header { display: none !important; }
    .container { grid-template-columns: 1fr; }
    section { box-shadow: none; border: 1px solid #ddd; page-break-inside: avoid; }
  }

  /* ── SCROLL BAR ── */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: #f1f5f9; }
  ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 3px; }
</style>
</head>
